# Entorno: development | production
ENVIRONMENT=development

# JWT - generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu-clave-secreta-aleatoria

# Base de datos
# Desarrollo (SQLite - por defecto, no requiere instalación):
# DATABASE_URL=sqlite:///./cotizador.db

# Producción (PostgreSQL):
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd

# --- Cardinal Assistance (Evoucher 2) ---
# Base URL: desarrollo o producción
CARDINAL_BASE_URL=https://ev2.bluesoft.com.ar/webservice
# CARDINAL_BASE_URL=https://evoucher.cardinalassistance.com/webservice
# Credenciales (backoffice Cardinal)
CARDINAL_AGENTE_EMISOR_GUID=52fc1910575c47b2c353d53c0f24035a
CARDINAL_AGENTE_EMISOR_SECRETO=d8c351886156c544dd5c8adfcc31cdfccd7c9ddd3726ecd362198a9f0403d8590ccf1e3a462d7ce5b8d00a08f1226167
# Email usado cuando la API de cotización lo exige como requerido
CARDINAL_DEFAULT_EMAIL=alberto@example.com
# IDs de destino Cardinal (obtener de POST /parametros con parametros=destinos)
# Mapeo: 1=Nacional, 2=Latinoamerica, 3=Europa, 4=Resto del mundo, 5=Norteamerica
# Origen AR se resuelve por nombre "Argentina" vía /parametros
CARDINAL_DESTINO_NACIONAL_ID=16
CARDINAL_DESTINO_EUROPA_ID=8
CARDINAL_DESTINO_LATINOAMERICA_ID=3
CARDINAL_DESTINO_RESTO_MUNDO_ID=9
