# Entorno: development | production
ENVIRONMENT=development

# CORS (separar múltiples orígenes con comas). Para pruebas rápidas: *
# CORS_ALLOW_ORIGINS=https://mi-frontend.com,https://staging-mi-frontend.com
CORS_ALLOW_ORIGINS=*

# JWT - generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu-clave-secreta-aleatoria

# Base de datos
# Desarrollo (SQLite - por defecto, no requiere instalación):
# DATABASE_URL=sqlite:///./cotizador.db

# Producción (PostgreSQL):
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd

# --- Cardinal Assistance (Evoucher 2) ---
# Base URL: desarrollo o producción
CARDINAL_BASE_URL=https://ev2.bluesoft.com.ar/webservice
# CARDINAL_BASE_URL=https://evoucher.cardinalassistance.com/webservice
# Credenciales (backoffice Cardinal)
CARDINAL_AGENTE_EMISOR_GUID=52fc1910575c47b2c353d53c0f24035a
CARDINAL_AGENTE_EMISOR_SECRETO=d8c351886156c544dd5c8adfcc31cdfccd7c9ddd3726ecd362198a9f0403d8590ccf1e3a462d7ce5b8d00a08f1226167
# Email usado cuando las APIs de cotización lo exigen como requerido (Cardinal, GoAssistance, etc.)
COTIZADOR_DEFAULT_EMAIL=info@biantravel.com
# IDs de destino Cardinal (obtener de POST /parametros con parametros=destinos)
# Mapeo: 1=Nacional, 2=Latinoamerica, 3=Europa, 4=Resto del mundo, 5=Norteamerica
# Origen AR se resuelve por nombre "Argentina" vía /parametros
CARDINAL_DESTINO_NACIONAL_ID=16
CARDINAL_DESTINO_EUROPA_ID=8
CARDINAL_DESTINO_LATINOAMERICA_ID=3
CARDINAL_DESTINO_RESTO_MUNDO_ID=9
CARDINAL_DESTINO_NORTEAMERICA_ID=12

# --- GoAssistance (ATV - Asegura Tu Viaje) ---
GO_ASSISTANCE_BASE_URL=https://sistema.aseguratuviaje.com/webapi18
# Código encriptado proporcionado por ATV (identifica quién solicita la cotización)
GO_ASSISTANCE_WEBSERVICE=

# --- Pax Assistance ---
# Ambientes:
# STG:  https://www.stg.paxassistance.com
# PROD: https://www.paxassistance.com
PAX_BASE_URL=https://www.stg.paxassistance.com
# API Key generada por Pax para este integrador
PAX_API_KEY=

# --- New Travel ---
# Ambientes:
# TEST: https://cacao.ilstechnik.com/api/v1
NEW_TRAVEL_BASE_URL=https://cacao.ilstechnik.com/api/v1
NEW_TRAVEL_USER=
NEW_TRAVEL_PASSWORD=

# --- Terrawind (SETW) ---
# Ambientes:
# TEST: https://sandbox.setw.net/emision/api/v2/
# PROD: https://emision.setw.net/api/v2
TERRAWIND_BASE_URL=https://sandbox.setw.net/emision/api/v2/
TERRAWIND_USER=
TERRAWIND_PASSWORD=

# --- Universal Assistance (Siebel SOAP) ---
# Endpoint QA (ajustar a PROD cuando corresponda)
UNIVERSAL_SOAP_URL=https://siebelqa.universal-assistance.com:8443/siebel/app/eai_anon/esn?SWEExtSource=SecureWebService&SWEExtCmd=Execute
UNIVERSAL_USERNAME=
UNIVERSAL_PASSWORD=
UNIVERSAL_ORGANIZACION_EMISORA=
UNIVERSAL_CONVENIO=
# Valores admitidos por el WS: Y / N / vacio (todos)
UNIVERSAL_FOLLETO=
# Mapeos del orquestador a Universal (completar con listas oficiales).
UNIVERSAL_PAIS_ORIGEN_AR=ARGENTINA
UNIVERSAL_DESTINO_NACIONAL=Territorio Nacional
UNIVERSAL_DESTINO_LATINOAMERICA=América del Sur (salvo Vzla)
UNIVERSAL_DESTINO_EUROPA=Europa
UNIVERSAL_DESTINO_RESTO_MUNDO=Internacional Mundo
UNIVERSAL_DESTINO_NORTEAMERICA=America del norte
UNIVERSAL_TIPO_VIAJE_UNICO_VIAJE=Un viaje
UNIVERSAL_TIPO_VIAJE_MULTIVIAJE=Varios viajes
UNIVERSAL_TIPO_VIAJE_LARGA_ESTADIA=
